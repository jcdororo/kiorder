// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SYSTEM_ADMIN
  STORE_OWNER
}

enum MenuItemType {
  FOOD
  DRINK
  SERVICE
}

model User {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String
    role      Role     @default(STORE_OWNER)
    createdAt DateTime @default(now())
    store     Store?
  }

  model Store {
    id            String         @id @default(uuid())
    userId        String         @unique
    name          String
    createdAt     DateTime       @default(now())
    user          User           @relation(fields: [userId], references: [id])
    tables        Table[]
    menuItems     MenuItem[]
    orders        Order[]
    waitingEntries WaitingEntry[]
  }

  model Table {
    id      String  @id @default(uuid())
    storeId String
    number  Int
    store   Store   @relation(fields: [storeId], references: [id])
    orders  Order[]
  }

  model MenuItem {
    id          String      @id @default(uuid())
    storeId     String
    name        String
    category    String
    price       Int
    image       String?
    description String?
    available   Boolean      @default(true)
    type        MenuItemType @default(FOOD)
    store       Store        @relation(fields: [storeId], references: [id])
    orderItems  OrderItem[]
  }

  model Order {
    id         String      @id @default(uuid())
    storeId    String
    tableId    String
    status     String      @default("접수됨")
    requests   String?
    startedAt   DateTime?
    completedAt DateTime?
    createdAt   DateTime  @default(now())
    store      Store       @relation(fields: [storeId], references: [id])
    table      Table       @relation(fields: [tableId], references: [id])
    orderItems OrderItem[]
  }

  model OrderItem {
    id         String   @id @default(uuid())
    orderId      String
    menuItemId   String
    name         String
    price        Int
    quantity     Int
    needsKitchen Boolean @default(true)
    order      Order    @relation(fields: [orderId], references: [id])
    menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  }

  model WaitingEntry {
    id            String   @id @default(uuid())
    storeId       String
    number        Int
    phone         String
    partySize     Int
    status        String   @default("대기중")
    guestResponse String?
    createdAt     DateTime @default(now())
    store         Store    @relation(fields: [storeId], references: [id])
  }